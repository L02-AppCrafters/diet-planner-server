PORT=4000
HEALTH_CHECK_URL=http://localhost:4000/health

# Public URL used when seeding recipe image URLs.
# Local Android Emulator: http://10.0.2.2:4000
# Local web/browser: http://localhost:4000
# Production: https://your-backend-domain.com
PUBLIC_ASSET_BASE_URL=http://10.0.2.2:4000

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/diet_planner

# JWT Access Token
JWT_SECRET=your-very-strong-access-secret-change-in-production
JWT_EXPIRES_IN=15m

# JWT Refresh Token
JWT_REFRESH_SECRET=your-very-strong-refresh-secret-change-in-production
JWT_REFRESH_EXPIRES_IN=7d
