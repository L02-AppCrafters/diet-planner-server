PORT=3000
# URL server tự gọi để health check (để trống sẽ dùng localhost:PORT)
HEALTH_CHECK_URL=https://your-app.onrender.com/health

DATABASE_URL=

# JWT Access Token
JWT_SECRET=your-very-strong-access-secret-change-in-production
JWT_EXPIRES_IN=15m

# JWT Refresh Token
JWT_REFRESH_SECRET=your-very-strong-refresh-secret-change-in-production
JWT_REFRESH_EXPIRES_IN=7d


